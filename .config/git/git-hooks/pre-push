#!/bin/sh
# Normally hands off to git-lfs so LFS blobs upload alongside their pointers.
#
# Opt a repo out with:   git config --local hooks.lfsPush false
# Commits still carry LFS pointers (the sha256 oid travels over git as a tiny
# text file), but the blobs never leave this machine. For files that are large
# and regenerated often -- model checkpoints, caches -- shipping them to the
# remote is pure cost, while the pointer still records exactly which artifact
# a commit was built from.
#
# Escape hatch: `git lfs push <remote> <ref>` still uploads on demand.
if [ "$(git config --type=bool --get hooks.lfsPush)" = "false" ]; then
	exit 0
fi

command -v git-lfs >/dev/null 2>&1 || { printf >&2 "\n%s\n\n" "This repository is configured for Git LFS but 'git-lfs' was not found on your path. If you no longer wish to use Git LFS, remove this hook by deleting the 'pre-push' file in the hooks directory (set by 'core.hookspath'; usually '.git/hooks')."; exit 2; }
git lfs pre-push "$@"
