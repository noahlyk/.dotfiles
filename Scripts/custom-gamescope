#!/usr/bin/env bash
set -euo pipefail

# default mode: plain
USE_SCOPE=0
case "${1:-}" in
  --scope)
    USE_SCOPE=1
    shift
    ;;
esac

# defaults
USE_VRR=0
USE_EXPOSE_WL=0
FULLSCREEN=1
FORCE_GRAB=1
USE_GAMEMODE=0
HUD_MODE="no_display"
FPS_CAP=""
REFRESH_RATE=""
DRY_RUN=0
W="" ; H=""
GW="" ; GH=""
SCALE_MODE=""   # new: -S option pass-through
SHARPNESS=""     # new: --sharpness option
USE_VKBASALT=0   # new: --vkbasalt option
USE_VKPOST=0     # new: --vkpost option
USE_EFFECTS=0    # new: --effects option (sharpness + contrast)
USE_EFFECTS_2=0  # new: --effects2 option (contrast heavy for saturated games)
FSR_SHARPNESS="" # new: --fsr option
FIXED_RES=1
AGGRESSIVE_MEM=0 # new: --aggressive-memory option
USE_STEAM=0 # new: --steam option (preserve Steam overlay)
USE_NTSYNC=0 # new: --ntsync option
USE_DLSS=0 # new: --dlss option
USE_HDR=0 # new: --hdr option
USE_CROSSHAIR=0 # new: --crosshair option
USE_IMMEDIATE_FLIPS=1
USE_RT=1

GAME_ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --720p) GW=1280; GH=720 ;;
    --900p) GW=1600; GH=900 ;;
    --1080p) GW=1920; GH=1080 ;;
    --1440p) GW=2560; GH=1440 ;;
    --res=*) r="${1#--res=}"; GW="${r%x*}"; GH="${r#*x}" ;;
    --hud) HUD_MODE="default" ;;
    --hud=*) HUD_MODE="${1#--hud=}" ;;
    --no-hud) HUD_MODE="no_display" ;;
    --vrr) USE_VRR=1 ;;
    --no-vrr) USE_VRR=0 ;;
    --expose-wayland) USE_EXPOSE_WL=1 ;;
    --no-expose-wayland) USE_EXPOSE_WL=0 ;;
    --windowed) FULLSCREEN=0 ;;
    --no-grab) FORCE_GRAB=0 ;;
    --fps=*) FPS_CAP="${1#--fps=}" ;;
    --refresh-rate=*) REFRESH_RATE="${1#--refresh-rate=}" ;;
    --gamemode) USE_GAMEMODE=1 ;;
    --no-gamemode) USE_GAMEMODE=0 ;;
    -S) SCALE_MODE="$2"; shift ;;  # pass-through
    --sharpness) SHARPNESS="$2"; shift ;;
    --vkbasalt) USE_VKBASALT=1 ;;
    --vkpost) USE_VKPOST=1 ;;
    --effects) USE_EFFECTS=1 ;;
    --effects2) USE_EFFECTS_2=1 ;;
    --fsr) FSR_SHARPNESS="$2"; shift ;;
    --no-fixed-res) FIXED_RES=0 ;;
    --aggressive-memory) AGGRESSIVE_MEM=1 ;;
    --steam) USE_STEAM=1 ;;
    --ntsync) USE_NTSYNC=1 ;;
    --dlss) USE_DLSS=1 ;;
    --hdr) USE_HDR=1 ;;
    --dry) DRY_RUN=1 ;;
    --crosshair) USE_CROSSHAIR=1 ;;
    --immediate-flips) USE_IMMEDIATE_FLIPS=1 ;;
    --no-immediate-flips) USE_IMMEDIATE_FLIPS=0 ;;
    --rt) USE_RT=1 ;;
    --no-rt) USE_RT=0 ;;
    --)
      shift
      GAME_ARGS+=("$@")
      break
      ;;
    -*)
      notify-send -u critical "custom-gamescope: unknown option: $1" "Run with --dry for usage"
      exit 1
      ;;
    *) GAME_ARGS+=("$1") ;;
  esac
  shift || true
done

if [[ ${#GAME_ARGS[@]} -eq 0 ]]; then
  echo "Usage: $0 [--scope] [opts] -- <cmd>" >&2
  echo "  --scope              Use gamescope" >&2
  echo "  --steam              Keep Steam overlay (may cause stutter)" >&2
  echo "  --ntsync             Enable NTSync for better frame pacing" >&2
  echo "  --dlss               Upgrade DLSS to latest version" >&2
  echo "  --hdr                Enable HDR output" >&2
  echo "  --refresh-rate=N     Set refresh rate (default: auto-detect from niri)" >&2
  echo "  --hud[=mode]         Enable MangoHud (default/full/minimal)" >&2
  echo "  --crosshair          Enable custom crosshair overlay" >&2
  echo "  --no-immediate-flips Disable immediate flips (on by default)" >&2
  echo "  --no-rt              Disable realtime scheduling (on by default)" >&2
  echo "  --vkpost             Enable vkpost (sharpening)" >&2
  echo "  --effects            Enable sharpening + contrast (Recommended)" >&2
  echo "  --effects2           Enable high-contrast mode for saturated games (The Finals, OW)" >&2
  echo "  --vrr                Enable VRR/adaptive-sync" >&2
  echo "  --gamemode           Use gamemode" >&2
  exit 1
fi

# output resolution auto-detect from niri
if [[ -z "$W" || -z "$H" ]]; then
  if out="$(niri msg focused-output 2>/dev/null | grep 'Current mode:' || true)"; then
    read -r W H <<<"$(sed -E 's/.* ([0-9]+)x([0-9]+).*/\1 \2/' <<<"$out")"
  fi
fi
[[ -n "$W" ]] || W=1920
[[ -n "$H" ]] || H=1080

# game resolution defaults to output if not set
[[ -z "$GW" ]] && GW="$W"
[[ -z "$GH" ]] && GH="$H"

# refresh rate: explicit or auto-detect from niri
if [[ -z "$REFRESH_RATE" ]]; then
  if out="$(niri msg focused-output 2>/dev/null | grep 'Current mode:' || true)"; then
    REFRESH_RATE="$(sed -E 's/.* @ ([0-9.]+) Hz.*/\1/' <<<"$out")"
  fi
fi

# environment
export mesa_glthread=true
export RADV_PERFTEST=gpl
export IS_GAME=1
export __GL_THREADED_OPTIMIZATION=1
export __GL_YIELD=NOTHING
export PROTON_WAIT_ATTACHED=0
export PROTON_ENABLE_WAYLAND=1
export PROTON_USE_EAC_LINUX=1

# Fix stuttering caused by Steam Game Recorder (Steam's LD_PRELOAD injection)
# Use --steam to preserve Steam overlay (but may cause stutter)
if [[ "$USE_STEAM" -eq 0 ]]; then
  export LD_PRELOAD=""
fi

# Proton performance options
[[ "$USE_NTSYNC" -eq 1 ]] && export PROTON_USE_NTSYNC=1
[[ "$USE_DLSS" -eq 1 ]] && export PROTON_DLSS_UPGRADE=1
[[ "$USE_HDR" -eq 1 ]] && export PROTON_ENABLE_HDR=1

# Lock game memory in RAM (only when aggressive-memory is used)
if [[ "$AGGRESSIVE_MEM" -eq 1 ]] && command -v mlock >/dev/null 2>&1; then
  export LD_PRELOAD="${LD_PRELOAD:+$LD_PRELOAD:}libmlock.so"
fi

# vkbasalt config
if [[ "$USE_VKBASALT" -eq 1 ]]; then
  export ENABLE_VKBASALT=1
  export VKBASALT_CONFIG_FILE="$HOME/.config/vkBasalt/vkBasalt.conf"
  export VK_ADD_LAYERS="VK_LAYER_VKBASALT_post_processing"
elif [[ "$USE_VKPOST" -eq 1 || "$USE_EFFECTS" -eq 1 ]]; then
  export ENABLE_VKPOST=1
  export VKPOST_CONFIG_FILE="$HOME/.config/vkPost/vkPost.conf"
elif [[ "$USE_EFFECTS_2" -eq 1 ]]; then
  export ENABLE_VKPOST=1
  export VKPOST_CONFIG_FILE="$HOME/.config/vkPost/vkPost2.conf"
else
  export ENABLE_VKBASALT=0
  export ENABLE_VKPOST=0
  unset VK_ADD_LAYERS || true
fi

if [[ "$USE_SCOPE" -eq 0 ]]; then
  if [[ "$HUD_MODE" != "no_display" ]]; then
    export MANGOHUD=1
  else
    unset MANGOHUD || true
  fi
fi

# Crosshair overlay config (krosshair Vulkan layer)
if [[ "$USE_CROSSHAIR" -eq 1 ]]; then
  export KROSSHAIR=1
fi

# dry-run output
if [[ "$DRY_RUN" -eq 1 ]]; then
  # Show enabled env vars
  [[ "$USE_NTSYNC" -eq 1 ]] && echo "PROTON_USE_NTSYNC=1"
  [[ "$USE_DLSS" -eq 1 ]] && echo "PROTON_DLSS_UPGRADE=1"
  [[ "$USE_HDR" -eq 1 ]] && echo "PROTON_ENABLE_HDR=1"
  
  if [[ "$USE_SCOPE" -eq 1 ]]; then
    printf 'DRY (scope) would run: '
    [[ "$USE_GAMEMODE" -eq 1 ]] && printf 'gamemoderun '
    # Show aggressive memory if enabled
    if [[ "$USE_GAMEMODE" -eq 1 && "$AGGRESSIVE_MEM" -eq 1 ]]; then
      printf 'sudo cgexec -g memory:games-premium '
    elif [[ "$USE_GAMEMODE" -eq 1 ]]; then
      printf 'sudo cgexec -g memory:games-premium '
    fi
    printf 'gamescope '
    if [[ "$FIXED_RES" -eq 1 ]]; then
      printf -- "-W %s -H %s -w %s -h %s " "$W" "$H" "$GW" "$GH"
    else
      printf -- "-w %s -h %s " "$GW" "$GH"
    fi
    [[ $FULLSCREEN -eq 1 ]] && printf -- "-f "
    [[ $USE_VRR -eq 1 ]] && printf -- "--adaptive-sync "
    [[ $USE_EXPOSE_WL -eq 1 ]] && printf -- "--expose-wayland "
    [[ $FORCE_GRAB -eq 1 ]] && printf -- "--force-grab-cursor --cursor=disabled "
    [[ -n "$SCALE_MODE" ]] && printf -- "-S %s " "$SCALE_MODE"
    [[ -n "$SHARPNESS" ]] && printf -- "--sharpness %s " "$SHARPNESS"
    [[ -n "$FSR_SHARPNESS" ]] && printf -- "--fsr-sharpness %s " "$FSR_SHARPNESS"
    [[ -n "$FPS_CAP" ]] && printf -- "--fps %s " "$FPS_CAP"
    [[ -n "$REFRESH_RATE" ]] && printf -- "-r %s " "$REFRESH_RATE"
    [[ $USE_IMMEDIATE_FLIPS -eq 1 ]] && printf -- "--immediate-flips "
    [[ $USE_RT -eq 1 ]] && printf -- "--rt "
    [[ "$HUD_MODE" != "no_display" ]] && printf -- "--mangoapp "
    printf -- "-- "
    printf '%q ' "${GAME_ARGS[@]}"
    echo
  else
    printf 'DRY (plain) would run: '
    # Show gamemoderun if enabled
    [[ "$USE_GAMEMODE" -eq 1 ]] && printf 'gamemoderun '
    printf '%q ' "${GAME_ARGS[@]}"
    echo
  fi
  exit 0
fi

# launch plain mode
if [[ "$USE_SCOPE" -eq 0 ]]; then
  exec setsid -w "${GAME_ARGS[@]}"
  exit 0
fi

# build gamescope command
CMD=()

# Use gamemoderun for CPU/GPU optimization
if [[ "$USE_GAMEMODE" -eq 1 ]]; then
  CMD+=(gamemoderun)
fi

if [[ "$FIXED_RES" -eq 1 ]]; then
  CMD+=(gamescope -W "$W" -H "$H" -w "$GW" -h "$GH")
else
  CMD+=(gamescope -w "$GW" -h "$GH")
fi

[[ "$FULLSCREEN" -eq 1 ]] && CMD+=(-f)
[[ "$USE_VRR" -eq 1 ]] && CMD+=(--adaptive-sync)
[[ "$USE_EXPOSE_WL" -eq 1 ]] && CMD+=(--expose-wayland)
[[ "$FORCE_GRAB" -eq 1 ]] && CMD+=(--force-grab-cursor --cursor=disabled)
[[ -n "$SCALE_MODE" ]] && CMD+=(-S "$SCALE_MODE")
[[ -n "$SHARPNESS" ]] && CMD+=(--sharpness "$SHARPNESS")
[[ -n "$FSR_SHARPNESS" ]] && CMD+=(--fsr-sharpness "$FSR_SHARPNESS")
[[ -n "$FPS_CAP" ]] && CMD+=(--fps "$FPS_CAP")
[[ -n "$REFRESH_RATE" ]] && CMD+=(-r "$REFRESH_RATE")
[[ "$USE_IMMEDIATE_FLIPS" -eq 1 ]] && CMD+=(--immediate-flips)
[[ "$USE_RT" -eq 1 ]] && CMD+=(--rt)
[[ "$HUD_MODE" != "no_display" ]] && CMD+=(--mangoapp)

# Crosshair overlay uses KROSSHAIR Vulkan layer env vars set above

CMD+=(-- "${GAME_ARGS[@]}")



# Run gamescope
set -m
"${CMD[@]}" &
GAMESCOPE_PID=$!
set +m

# Set up aggressive memory mode AFTER starting gamescope
if [[ "$USE_GAMEMODE" -eq 1 && "$AGGRESSIVE_MEM" -eq 1 ]]; then
  # Save original swappiness
  ORIGINAL_SWAPPINESS=$(cat /proc/sys/vm/swappiness 2>/dev/null || echo 60)
  
  echo "🚀 Aggressive memory mode: optimizing memory for gaming..."
  
  # Extract game name dynamically from the command we're running
  GAME_BASENAME=$(basename "${GAME_ARGS[0]}" | sed 's/\.[^.]*$//')
  echo "🎮 Detected game: $GAME_BASENAME"
  
  # Single pkexec call to set everything up and get sudo access
  sudo bash -c '
    # Set high swappiness to force other apps to swap and make room
    sysctl vm.swappiness=80 2>/dev/null || true
    
    # Protect the game we are running FIRST
    for pid in $(pgrep -u '$USER' -f "'$GAME_BASENAME'" 2>/dev/null); do
      echo -1000 | tee "/proc/$pid/oom_score_adj" 2>/dev/null && echo "🛡️ Protected game PID $pid"
    done
    
    # Also protect gamescope
    for pid in $(pgrep -u '$USER' "gamescope" 2>/dev/null); do
      echo -1000 | tee "/proc/$pid/oom_score_adj" 2>/dev/null && echo "🛡️ Protected gamescope PID $pid"
    done
    
    # Penalize memory-heavy apps to free up 1-2GB overhead
    for app in firefox discord chrome steam spotify; do
      for pid in $(pgrep -u '$USER' "$app" 2>/dev/null | head -3); do
        echo 500 | tee "/proc/$pid/oom_score_adj" 2>/dev/null || true
        echo "⚠️ Penalized $app PID $pid to free memory"
      done
    done
  '
  
  # Refresh sudo credentials for the rest of the session
  sudo -v
  
  # Protect this script and all children (including the game)
  echo $$ | sudo tee /proc/self/oom_score_adj >/dev/null
  echo "🛡️ Protected script PID $$ and all children"
  
  # Wait a moment for game to start
  sleep 3
  
  # Protect the game processes directly and keep checking for new ones
  echo "Monitoring for new game processes..."
  (
    while true; do
      protected_any=0
      
      # Get all game processes
      for pid in $(pgrep -u $USER -f "$GAME_BASENAME" 2>/dev/null); do
        current_score=$(cat "/proc/$pid/oom_score_adj" 2>/dev/null || echo 0)
        if [[ "$current_score" != "-1000" ]]; then
          echo -1000 | sudo tee "/proc/$pid/oom_score_adj" 2>/dev/null && echo "Protected game PID $pid (was $current_score)"
          protected_any=1
        fi
      done
      
      # If no new processes found in the last check, break
      if [[ "$protected_any" -eq 0 ]]; then
        echo "No new game processes found, monitoring complete"
        break
      fi
      
      sleep 10
    done
    
    # Also protect gamescope
    for pid in $(pgrep -u $USER "gamescope" 2>/dev/null); do
      echo -1000 | sudo tee "/proc/$pid/oom_score_adj" 2>/dev/null && echo "Protected gamescope PID $pid"
    done
  ) &
  
  # Cleanup function to restore original settings
  cleanup() {
    echo "🔄 Restoring original swappiness ($ORIGINAL_SWAPPINESS)..."
    
    # Use sudo (should still have auth) to restore settings
    echo "$ORIGINAL_SWAPPINESS" | sudo tee /proc/sys/vm/swappiness 2>/dev/null || true
    
    # Reset OOM scores for all processes to default
    for pid in $(pgrep -u $USER 2>/dev/null); do
      if [[ -f "/proc/$pid/oom_score_adj" ]]; then
        echo 0 | sudo tee "/proc/$pid/oom_score_adj" 2>/dev/null || true
      fi
    done
  }
  
  # Set up cleanup on game exit
  trap "cleanup" EXIT INT TERM
fi

wait $GAMESCOPE_PID

# Cleanup after game exits
if [[ "$USE_GAMEMODE" -eq 1 && "$AGGRESSIVE_MEM" -eq 1 ]]; then
  echo "🔄 Restoring original swappiness ($ORIGINAL_SWAPPINESS)..."
  
  # Use pkexec to restore settings (ensure we have permissions)
  sudo bash -c "
    echo '$ORIGINAL_SWAPPINESS' | tee /proc/sys/vm/swappiness 2>/dev/null || true
    echo 'Swappiness restored to $ORIGINAL_SWAPPINESS'
    
    # Reset OOM scores for all processes to default
    for pid in \$(pgrep -u $USER 2>/dev/null); do
      if [[ -f '/proc/\$pid/oom_score_adj' ]]; then
        echo 0 | tee '/proc/\$pid/oom_score_adj' 2>/dev/null || true
      fi
    done
    echo 'OOM scores reset to default'
  "
fi
